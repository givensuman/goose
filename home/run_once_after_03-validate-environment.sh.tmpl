#!/bin/bash

set -euox pipefail

readonly SCRIPT_NAME="validate-environment"
readonly LOG_PREFIX="[chezmoi/${SCRIPT_NAME}]"

log_info() {
  echo "${LOG_PREFIX} INFO: $*" >&2
}

log_warn() {
  echo "${LOG_PREFIX} WARN: $*" >&2
}

log_info "Validating environment configuration..."

VALIDATION_FAILED=0

# Check critical tools
readonly CRITICAL_TOOLS=("bash" "git" "curl")
for tool in "${CRITICAL_TOOLS[@]}"; do
  if command -v "$tool" &> /dev/null; then
    log_info "✓ $tool found"
  else
    log_warn "✗ $tool not found"
    VALIDATION_FAILED=1
  fi
done

# Check optional but recommended tools
readonly OPTIONAL_TOOLS=("fish" "mise" "nvim" "bat" "lazygit" "yazi")
for tool in "${OPTIONAL_TOOLS[@]}"; do
  if command -v "$tool" &> /dev/null; then
    log_info "✓ $tool found"
  else
    log_warn "✗ $tool not in PATH (will be installed by mise if needed)"
  fi
done

# Check critical directories
readonly CRITICAL_DIRS=("$HOME/.config" "$HOME/.local")
for dir in "${CRITICAL_DIRS[@]}"; do
  if [[ -d "$dir" ]]; then
    log_info "✓ Directory exists: $dir"
  else
    log_warn "✗ Directory missing: $dir (will be created if needed)"
  fi
done

if [[ $VALIDATION_FAILED -eq 0 ]]; then
  log_info "Environment validation completed successfully"
  exit 0
else
  log_warn "Environment validation completed with warnings (non-fatal)"
  exit 0
fi
